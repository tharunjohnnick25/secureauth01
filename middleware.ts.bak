/**
 * NOTE (STABILIZATION): middleware.ts intentionally converted to a no-op.
 * The previous middleware performed session checks and role redirects at the
 * edge runtime and caused conflicts with the App Router, duplicate auth
 * checks, and hydration issues in several environments.
 *
 * Removing middleware logic entirely from the project (delete) is recommended
 * for Next.js App Router applications where route handlers and server
 * components are used for auth checks. Deletion is not performed by the
 * automated fixer to avoid accidental loss — instead we disable it by
 * setting an empty matcher and fast-path behavior. This prevents runtime
 * middleware processing while keeping the file for audit.
 */

import { NextResponse, type NextRequest } from 'next/server';

export default function middleware(_request: NextRequest) {
  // No-op middleware: let App Router and server-side route handlers manage
  // authentication, redirects, and role checks. This avoids double handling
  // and prevents middleware <-> proxy conflicts.
  return NextResponse.next();
}

// Empty matcher => middleware won't run for any route.
export const config = { matcher: [] };
